# Example environment variables for the backend (do NOT commit secrets for production)
#
# Use these as a template. For docker-compose (containerized) the DB host inside the
# compose network is `postgres`; for running the backend locally against a host
# Postgres instance, use `localhost`.

# JDBC URL for PostgreSQL. Example for local development:
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/skillsync
# Database credentials
SPRING_DATASOURCE_USERNAME=skillsync_user
SPRING_DATASOURCE_PASSWORD=skillsync123

# Application JWT settings (replace the secret in production)
APP_JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
# Token expiration in milliseconds (default 1 day)
APP_JWT_EXPIRATION=86400000

# Optional: Spring profile to use when running locally
# SPRING_PROFILES_ACTIVE=dev

